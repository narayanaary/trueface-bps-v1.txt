from fastapi import FastAPI, UploadFile, Form
import requests

app = FastAPI()

def check_payhip(key):
    # Replace YOUR_PRODUCT_ID with your actual Payhip product ID
    url = f"https://payhip.com/api/v1/license/verify?product_id=YOUR_PRODUCT_ID&license_key={key}"
    return requests.get(url).status_code == 200

@app.post("/verify")
async def verify(file: UploadFile, key: str = Form(...)):
    if not check_payhip(key):
        return {"error": "Invalid License"}
    
    # Placeholder for TrueFace BPS model logic
    return {"status": "Verified", "file": file.filename}

